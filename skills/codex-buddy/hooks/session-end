#!/usr/bin/env bash
# SessionEnd hook for codex-buddy plugin (W7).
#
# Asks the per-worktree broker (if any) to shut down cleanly. Idempotent:
# if no broker is running for this cwd, it's a no-op.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read hook stdin (Claude Code passes a JSON envelope on stdin). We only need cwd.
hook_input=""
if [ ! -t 0 ]; then
  hook_input=$(cat 2>/dev/null || true)
fi

cwd_from_hook="$(printf '%s' "$hook_input" | sed -n 's/.*"cwd"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
project_dir="${cwd_from_hook:-${PWD}}"

if [ -x "$(command -v node)" ]; then
  node "${PLUGIN_ROOT}/scripts/buddy-broker-cli.mjs" stop --project-dir "$project_dir" >/dev/null 2>&1 || true
fi

# SessionEnd hook: succeed silently. No additional context to inject.
exit 0
