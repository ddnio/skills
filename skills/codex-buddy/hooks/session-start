#!/usr/bin/env bash
# SessionStart hook for codex-buddy plugin
#
# Stage5e: per-worktree buddy_session_id isolation + handoff injection.
# - cwd from hook stdin keys ~/.buddy/state/by-cwd/<sha256(cwd)[:8]>.json
#   (concurrent Claude sessions in different worktrees no longer collide)
# - <cwd>/docs/SESSION_HANDOFF.md is read and prepended to additionalContext
#   if it exists, so the next Claude session resumes with explicit context.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read SKILL.md content
skill_content=$(cat "${PLUGIN_ROOT}/SKILL.md" 2>&1 || echo "Error reading codex-buddy SKILL.md")

# Read hook stdin (Claude Code passes JSON envelope: source/session_id/cwd/transcript_path)
hook_input=""
if [ ! -t 0 ]; then
  hook_input=$(cat 2>/dev/null || true)
fi
trigger="$(printf '%s' "$hook_input" | sed -n 's/.*"source"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
[ -z "$trigger" ] && trigger="startup"
hook_cwd="$(printf '%s' "$hook_input" | sed -n 's/.*"cwd"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
[ -z "$hook_cwd" ] && hook_cwd="${PWD}"

BUDDY_HOME_DIR="${BUDDY_HOME:-${HOME}/.buddy}"
mkdir -p "$BUDDY_HOME_DIR"
mkdir -p "$BUDDY_HOME_DIR/state/by-cwd"

# Rotate buddy_session_id (skip on compact to preserve event grouping).
# Writes BOTH per-cwd state file (primary) and legacy global file (compat).
if [ "$trigger" != "compact" ] && [ -x "$(command -v node)" ]; then
  node -e "
    const fs = require('fs');
    const path = require('path');
    const crypto = require('crypto');
    const home = process.argv[1];
    const trigger = process.argv[2];
    const cwd = process.argv[3];
    const sid = 'buddy-' + crypto.randomUUID().slice(0, 8);
    const updated = new Date().toISOString();
    const cwdHash = crypto.createHash('sha256').update(cwd).digest('hex').slice(0, 8);
    // Primary: per-cwd state.
    const perCwd = path.join(home, 'state', 'by-cwd', cwdHash + '.json');
    fs.writeFileSync(perCwd, JSON.stringify({ buddy_session_id: sid, cwd, updated, trigger }));
    // Compat: legacy global pointer (older runtimes / tools still see it).
    fs.writeFileSync(path.join(home, 'buddy-session.json'),
      JSON.stringify({ buddy_session_id: sid, created_at: updated, trigger }));
  " "$BUDDY_HOME_DIR" "$trigger" "$hook_cwd" 2>/dev/null || true
fi

# Read SESSION_HANDOFF.md from cwd (project root). Convention: docs/SESSION_HANDOFF.md.
# Cap at 8KB to keep additionalContext manageable.
handoff_content=""
HANDOFF_FILE="${hook_cwd}/docs/SESSION_HANDOFF.md"
if [ -f "$HANDOFF_FILE" ]; then
  handoff_content=$(head -c 8192 "$HANDOFF_FILE" 2>/dev/null || true)
fi

# Run preflight check (after rotation so call_count is for the new session)
preflight_result=""
if [ -x "$(command -v node)" ]; then
  preflight_result=$(node "${PLUGIN_ROOT}/scripts/buddy-runtime.mjs" --action preflight --project-dir "$hook_cwd" 2>/dev/null || echo '{"status":"error","message":"preflight failed"}')
fi

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_escaped=$(escape_for_json "$skill_content")
preflight_escaped=$(escape_for_json "$preflight_result")
handoff_escaped=$(escape_for_json "$handoff_content")

# Compose context. Handoff goes FIRST (above SKILL.md) so Claude sees "where we left off"
# before the verification policy.
if [ -n "$handoff_content" ]; then
  session_context="<SESSION_HANDOFF>\n${handoff_escaped}\n</SESSION_HANDOFF>\n\n<EXTREMELY_IMPORTANT>\ncodex-buddy verification policy is now active for this session.\nPreflight: ${preflight_escaped}\n\n**Below is the full content of your 'codex-buddy' skill. Follow it for every turn in this conversation:**\n\n${skill_escaped}\n</EXTREMELY_IMPORTANT>"
else
  session_context="<EXTREMELY_IMPORTANT>\ncodex-buddy verification policy is now active for this session.\nPreflight: ${preflight_escaped}\n\n**Below is the full content of your 'codex-buddy' skill. Follow it for every turn in this conversation:**\n\n${skill_escaped}\n</EXTREMELY_IMPORTANT>"
fi

# Output context injection
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
