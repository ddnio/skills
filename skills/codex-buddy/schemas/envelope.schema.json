{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://buddy.nanafox.com/schemas/envelope.schema.json",
  "title": "Buddy Decision Envelope (bare)",
  "description": "Bare verification decision envelope — the in-memory shape produced by createEnvelope(). Persisted audit rows extend this with v2 metadata; see audit-row-v2.schema.json.",
  "type": "object",
  "required": [
    "turn",
    "level",
    "rule",
    "triggered",
    "route",
    "evidence",
    "conclusion"
  ],
  "properties": {
    "turn":       { "type": "integer", "minimum": 0, "description": "Turn number in the verification sequence" },
    "level":      { "type": "string", "enum": ["V0", "V1", "V2", "V3"] },
    "rule":       { "type": "string", "minLength": 1 },
    "triggered":  { "type": "boolean" },
    "route":      { "type": "string", "enum": ["local", "codex", "both", "none"] },
    "evidence":   { "type": "array", "items": { "type": "string" } },
    "conclusion": { "type": "string", "enum": ["proceed", "stop", "needs-evidence", "needs-review", "skipped"] },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "unverified": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
